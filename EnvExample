OPENAI_MODEL=gpt-3.5-turbo

# ProxyAPI — только CLI openai_proxyapi.py
PROXYAPI_API_KEY=
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
PROXYAPI_MODEL=gpt-3.5-turbo

# GenAPI (genapi_chat.py; бот при API_PROVIDER=genapi)
GENAPI_KEY=
